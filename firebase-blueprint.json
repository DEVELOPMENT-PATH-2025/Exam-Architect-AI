{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "university": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "createdAt"]
    },
    "Curriculum": {
      "title": "Curriculum",
      "description": "Uploaded curriculum mapping.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "universityName": { "type": "string" },
        "semester": { "type": "string" },
        "rawSyllabusText": { "type": "string" },
        "subjects": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "code": { "type": "string" },
              "topics": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "createdAt"]
    },
    "Question": {
      "title": "Question",
      "description": "Specific question in the bank.",
      "type": "object",
      "properties": {
        "subjectId": { "type": "string" },
        "type": { "enum": ["short", "long", "numerical", "diagram"] },
        "text": { "type": "string" },
        "marks": { "type": "number" },
        "modelAnswer": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "diagramDescription": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subjectId", "type", "text", "marks"]
    },
    "PracticeSession": {
      "title": "Practice Session",
      "description": "Student's practice record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subjectId": { "type": "string" },
        "answers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "questionId": { "type": "string" },
              "userAnswer": { "type": "string" },
              "score": { "type": "number" },
              "feedback": { "type": "string" }
            }
          }
        },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "subjectId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/curricula/{curriculumId}": {
      "schema": "Curriculum",
      "description": "Stored curricula"
    },
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Global or user-specific question bank"
    },
    "/practiceSessions/{sessionId}": {
      "schema": "PracticeSession",
      "description": "User answers and evaluations"
    }
  }
}
