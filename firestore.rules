rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Note: AI Studio environment might have email_verified as false for some mock users, 
    // but standard hardened rules require it. For this setup, we'll stick to isOwner.
    // Uncomment below if strict verification is required.
    // function isVerifiedOwner(uid) {
    //   return isOwner(uid) && request.auth.token.email_verified == true;
    // }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Phase 4: Validation Blueprints
    
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email'])
        && data.userId is string && data.userId.size() <= 128
        && data.email is string && data.email.size() <= 200
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 200))
        && (!('university' in data) || (data.university is string && data.university.size() <= 200))
        && (!('department' in data) || (data.department is string && data.department.size() <= 200))
        && (!('year' in data) || (data.year is string && data.year.size() <= 100))
        && (!('bio' in data) || (data.bio is string && data.bio.size() <= 1000))
        && (!('updatedAt' in data) || data.updatedAt is timestamp)
        && (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidCurriculum(data) {
      return data.keys().hasAll(['userId', 'subjects'])
        && data.userId is string && data.userId.size() <= 128
        && data.subjects is list && data.subjects.size() <= 100;
    }

    function isValidPracticeSession(data) {
      return data.keys().hasAll(['userId', 'subjectId'])
        && data.userId is string && data.userId.size() <= 128
        && data.subjectId is string && data.subjectId.size() <= 128;
    }

    // Collections

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().userId == existing().userId
        && incoming().email == existing().email;
    }

    match /curricula/{curriculumId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      // Secure List Query: Rule itself MUST check resource.data
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(curriculumId) 
        && incoming().userId == request.auth.uid 
        && isValidCurriculum(incoming());
        
      allow update: if isSignedIn() 
        && existing().userId == request.auth.uid 
        && isValidCurriculum(incoming())
        && incoming().userId == existing().userId;
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Broad for now, usually restrict to admin/system
    }

    match /practiceSessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && incoming().userId == request.auth.uid 
        && isValidPracticeSession(incoming());
        
      allow update: if isSignedIn() 
        && existing().userId == request.auth.uid 
        && incoming().userId == existing().userId;
    }
  }
}
